{
	"name": "@iwsio/fetch",
	"version": "2.1.9",
	"license": "BSD-3-Clause",
	"description": "A simple set of functions to enable typed fetching using built-in fetch.",
	"repository": "github:iwsllc/iwsio-packages",
	"scripts": {
		"checks": "pnpm run '/^checks:/'",
		"checks:test": "pnpm test",
		"checks:lint": "pnpm lint",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:fix:unsafe": "biome check --write --unsafe .",
		"clean": "del-cli '**/dist' '**/coverage' '**/*.tsbuildinfo'",
		"test": "vitest --run --passWithNoTests",
		"server": "node ./src/__mocks__/server.cjs",
		"build": "tsc --build tsconfig.build.json",
		"prewatch": "tsc --build --clean tsconfig.build.json",
		"watch": "tsc --build watch --preserveWatchOutput tsconfig.build.json"
	},
	"author": "Nathan Bridgewater",
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js"
		}
	},
	"devDependencies": {
		"@iwsio/tsconfig": "workspace:*",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.6.0",
		"express": "^5.2.1",
		"jsdom": "^29.1.1",
		"morgan": "^1.11.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rimraf": "^6.1.3",
		"tslib": "^2.8.1",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"react": ">= 18 < 20",
		"react-dom": ">= 18 < 20"
	}
}
